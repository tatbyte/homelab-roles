{# roles/monitor_collect/templates/monitor-collect-web-compose.yml.j2 #}
# Managed by Ansible: monitor_collect
# Source: roles/monitor_collect/templates/monitor-collect-web-compose.yml.j2
services:
  {{ monitor_collect_web_compose_service_name }}:
    image: {{ monitor_collect_web_image }}
    container_name: {{ monitor_collect_web_container_name }}
    restart: unless-stopped
    volumes:
      - {{ monitor_collect_web_publish_dir }}:/usr/share/nginx/html:ro
      - {{ monitor_collect_web_nginx_conf_path }}:/etc/nginx/conf.d/default.conf:ro
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ monitor_collect_web_proxy_network_name }}"
      - "traefik.http.routers.{{ monitor_collect_web_router_name }}.rule=Host(`{{ monitor_collect_web_host }}`)"
      - "traefik.http.routers.{{ monitor_collect_web_router_name }}.entrypoints={{ monitor_collect_web_router_entrypoints | join(',') }}"
      - "traefik.http.routers.{{ monitor_collect_web_router_name }}.tls=true"
      - "traefik.http.routers.{{ monitor_collect_web_router_name }}.tls.certresolver={{ monitor_collect_web_tls_certresolver }}"
{% if monitor_collect_web_basic_auth_enabled %}
      - "traefik.http.routers.{{ monitor_collect_web_router_name }}.middlewares={{ monitor_collect_web_basic_auth_middleware }}"
      - "traefik.http.middlewares.{{ monitor_collect_web_basic_auth_middleware }}.basicauth.users={{ monitor_collect_web_basic_auth_users | map('replace', '$', '$$') | join(',') }}"
{% endif %}
      - "traefik.http.services.{{ monitor_collect_web_router_name }}.loadbalancer.server.port={{ monitor_collect_web_container_port }}"
    networks:
      - proxy

networks:
  proxy:
    external: true
    name: {{ monitor_collect_web_proxy_network_name }}
