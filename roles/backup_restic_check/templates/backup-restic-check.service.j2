{# roles/backup_restic_check/templates/backup-restic-check.service.j2 #}
{# Template for the managed systemd service unit in `backup_restic_check`. #}
[Unit]
Description=Run managed Restic repository check
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User={{ backup_restic_check_service_user }}
Group={{ backup_restic_check_service_group }}
EnvironmentFile={{ backup_restic_check_environment_file_path }}
ExecStart={{ backup_restic_check_script_path }}
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
