# Managed by Ansible: user_zshell
# Source: roles/user_zshell/tasks/config.yml

# ----- Shared login/profile baseline -----
if [ -f "$HOME/.profile" ]; then
  . "$HOME/.profile"
fi

# ----- Editors -----
export EDITOR={{ (user_zshell_environment.get('EDITOR', 'vim')) | quote }}
export VISUAL={{ (user_zshell_environment.get('VISUAL', 'vim')) | quote }}

# ----- History -----
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_REDUCE_BLANKS

# ----- Navigation -----
setopt AUTO_CD
setopt EXTENDED_GLOB

# Optional
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt INTERACTIVE_COMMENTS

# ----- Completion -----
autoload -Uz compinit
compinit -d ~/.cache/zsh/zcompdump

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}

# ----- Prompt (VS Code dark theme, git-aware, error inline) -----
setopt PROMPT_SUBST
autoload -Uz vcs_info

zstyle ':vcs_info:*' enable git
zstyle ':vcs_info:git:*' formats ' %F{yellow}⎇ [%b]%f'

precmd() { vcs_info }

PROMPT=$'%(?..%F{red}✘ %?\n%f)%B%F{blue}%n%f%B@%F{magenta}%m%f %F{cyan}%~%f${vcs_info_msg_0_} %F{green}%#%f '

{% if user_zshell_path_additions | length > 0 %}
# ----- Paths -----
{% for user_zshell_path in user_zshell_path_additions | reverse %}
if [ -d {{ user_zshell_path | quote }} ]; then
  case ":$PATH:" in
    *:{{ user_zshell_path }}:*) ;;
    *) PATH={{ user_zshell_path | quote }}:"$PATH" ;;
  esac
fi
{% endfor %}
export PATH
{% endif %}

{% if (user_zshell_environment | dict2items | rejectattr('key', 'in', ['EDITOR', 'VISUAL'])) | list | length > 0 %}
# ----- Extra environment -----
{% for user_zshell_env in user_zshell_environment | dict2items | rejectattr('key', 'in', ['EDITOR', 'VISUAL']) | sort(attribute='key') %}
export {{ user_zshell_env.key }}={{ user_zshell_env.value | quote }}
{% endfor %}
{% endif %}

# ----- Aliases -----
{% for user_zshell_alias in user_zshell_aliases | dictsort %}
alias {{ user_zshell_alias[0] }}={{ user_zshell_alias[1] | quote }}
{% endfor %}

# ----- Safety -----
setopt NO_BEEP
