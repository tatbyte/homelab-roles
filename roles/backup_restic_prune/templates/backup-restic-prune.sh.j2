{# roles/backup_restic_prune/templates/backup-restic-prune.sh.j2 #}
{# Template for the managed Restic prune script in `backup_restic_prune`. #}
#!/usr/bin/env bash
# Managed by Ansible: backup_restic_prune
# Source: roles/backup_restic_prune/templates/backup-restic-prune.sh.j2

set -u -o pipefail
umask 077

status_path={{ backup_restic_prune_status_path | to_json }}
repository_label={{ backup_restic_prune_repository_label | to_json }}
host_name={{ backup_restic_prune_status_host | to_json }}
job_name={{ backup_restic_prune_job_name | to_json }}
json_schema={{ backup_restic_prune_json_schema | to_json }}
host_filter={{ backup_restic_prune_host_filter | to_json }}

keep_last={{ backup_restic_prune_keep_last | int }}
keep_hourly={{ backup_restic_prune_keep_hourly | int }}
keep_daily={{ backup_restic_prune_keep_daily | int }}
keep_weekly={{ backup_restic_prune_keep_weekly | int }}
keep_monthly={{ backup_restic_prune_keep_monthly | int }}
keep_yearly={{ backup_restic_prune_keep_yearly | int }}

configured_extra_args=(
{% for item in backup_restic_prune_extra_args %}
  {{ item | to_json }}
{% endfor %}
)

cleanup_files=()

register_cleanup_file() {
  cleanup_files+=("$1")
}

cleanup() {
  local path
  for path in "${cleanup_files[@]}"; do
    rm -f "$path"
  done
}

trap cleanup EXIT

status_dir="$(dirname "$status_path")"
mkdir -p "$status_dir"

tmp_stdout="$(mktemp)"
register_cleanup_file "$tmp_stdout"
tmp_stderr="$(mktemp)"
register_cleanup_file "$tmp_stderr"
tmp_json="$(mktemp)"
register_cleanup_file "$tmp_json"

write_status_json() {
  local timestamp="$1"
  local status="$2"
  local duration_seconds="$3"
  local warnings_json="$4"
  local error_text="$5"
  local exit_code="$6"

  jq -n \
    --arg schema "$json_schema" \
    --arg host "$host_name" \
    --arg job "$job_name" \
    --arg timestamp "$timestamp" \
    --arg status "$status" \
    --arg repository "$repository_label" \
    --arg error "$error_text" \
    --arg host_filter_value "$host_filter" \
    --argjson duration_seconds "$duration_seconds" \
    --argjson keep_last "$keep_last" \
    --argjson keep_hourly "$keep_hourly" \
    --argjson keep_daily "$keep_daily" \
    --argjson keep_weekly "$keep_weekly" \
    --argjson keep_monthly "$keep_monthly" \
    --argjson keep_yearly "$keep_yearly" \
    --argjson warnings "$warnings_json" \
    --argjson exit_code "$exit_code" \
    '{
      schema: $schema,
      host: $host,
      job: $job,
      timestamp: $timestamp,
      status: $status,
      repository: $repository,
      duration_seconds: $duration_seconds,
      forget_policy: {
        host_filter: $host_filter_value,
        keep_last: $keep_last,
        keep_hourly: $keep_hourly,
        keep_daily: $keep_daily,
        keep_weekly: $keep_weekly,
        keep_monthly: $keep_monthly,
        keep_yearly: $keep_yearly
      },
      warnings: $warnings,
      error: $error,
      exit_code: $exit_code
    }' >"$tmp_json"

  install -m 0644 "$tmp_json" "$status_path"
}

start_epoch="$(date +%s)"

restic_global_args=()

{% if backup_restic_prune_lock_wait | trim | length > 0 %}
restic_global_args+=(
  --lock-wait {{ backup_restic_prune_lock_wait | to_json }}
)
{% endif %}

restic_prune_args=(
  forget
  --prune
)

if [ -n "$host_filter" ]; then
  restic_prune_args+=(--host "$host_filter")
fi

if [ "$keep_last" -gt 0 ]; then
  restic_prune_args+=(--keep-last "$keep_last")
fi
if [ "$keep_hourly" -gt 0 ]; then
  restic_prune_args+=(--keep-hourly "$keep_hourly")
fi
if [ "$keep_daily" -gt 0 ]; then
  restic_prune_args+=(--keep-daily "$keep_daily")
fi
if [ "$keep_weekly" -gt 0 ]; then
  restic_prune_args+=(--keep-weekly "$keep_weekly")
fi
if [ "$keep_monthly" -gt 0 ]; then
  restic_prune_args+=(--keep-monthly "$keep_monthly")
fi
if [ "$keep_yearly" -gt 0 ]; then
  restic_prune_args+=(--keep-yearly "$keep_yearly")
fi

configured_extra_args_count="$(printf '%s\n' "${configured_extra_args[@]}" | sed '/^$/d' | wc -l)"
if [ "$configured_extra_args_count" -gt 0 ]; then
  restic_prune_args+=("${configured_extra_args[@]}")
fi

if restic "${restic_global_args[@]}" "${restic_prune_args[@]}" >"$tmp_stdout" 2>"$tmp_stderr"; then
  restic_rc=0
else
  restic_rc=$?
fi

if [ -s "$tmp_stderr" ]; then
  warnings_json="$(
    jq -R -s 'split("\n") | map(select(length > 0))' "$tmp_stderr"
  )"
else
  warnings_json='[]'
fi

warning_count="$(
  jq -nr --argjson warnings "$warnings_json" '$warnings | length'
)"

end_epoch="$(date +%s)"
duration_seconds="$(( end_epoch - start_epoch ))"

json_status="ok"
error_text=""
if [ "$restic_rc" -ne 0 ]; then
  json_status="error"
  error_text="$(
    jq -nr --argjson warnings "$warnings_json" '$warnings | join(" | ")'
  )"
  if [ -z "$error_text" ]; then
    error_text="restic forget --prune failed with exit code $restic_rc"
  fi
elif [ "$warning_count" -gt 0 ]; then
  json_status="warn"
fi

write_status_json \
  "$(date --iso-8601=seconds)" \
  "$json_status" \
  "$duration_seconds" \
  "$warnings_json" \
  "$error_text" \
  "$restic_rc"

exit "$restic_rc"
