{# roles/monitoring_web/templates/monitor-collect-host.html.j2 #}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ monitoring_web_title }} Host</title>
  <meta name="theme-color" content="{{ monitoring_web_theme_color }}">
  <link rel="manifest" href="../../manifest.webmanifest">
  <link rel="icon" href="../../icon-192.png" sizes="192x192" type="image/png">
  <link rel="icon" href="../../icon-512.png" sizes="512x512" type="image/png">
  <link rel="icon" href="../../icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="../../icon-180.png">
  <style>
    :root {
      --bg: #071019;
      --bg-2: #0c1723;
      --panel: rgba(14, 24, 38, 0.92);
      --panel-strong: rgba(10, 18, 30, 0.96);
      --ink: #e7f1ff;
      --muted: #8ea6c0;
      --line: rgba(111, 142, 178, 0.24);
      --ok: #39d98a;
      --review: #5cc8ff;
      --warn: #ffb84d;
      --fail: #ff6b81;
      --accent: #5cc8ff;
      --accent-2: #6ef7d2;
      --shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      color: var(--ink);
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      user-select: text;
      -webkit-user-select: text;
      background:
        radial-gradient(circle at top left, rgba(92, 200, 255, 0.14), transparent 26%),
        radial-gradient(circle at 85% 10%, rgba(110, 247, 210, 0.08), transparent 22%),
        linear-gradient(180deg, #050b12 0%, var(--bg) 55%, #04080d 100%);
    }
    code, pre, .mono {
      font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    }
    .app {
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      min-height: 100vh;
    }
    .sidebar {
      position: sticky;
      top: 0;
      align-self: start;
      height: 100vh;
      padding: 1.4rem 1.1rem;
      border-right: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(10, 18, 30, 0.96) 0%, rgba(7, 16, 25, 0.9) 100%);
    }
    .brand { margin-bottom: 1.4rem; }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.3rem 0.6rem;
      border-radius: 999px;
      border: 1px solid rgba(92, 200, 255, 0.26);
      background: rgba(92, 200, 255, 0.08);
      color: var(--accent);
      font-size: 0.74rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .brand h1 {
      margin: 0.8rem 0 0;
      font-size: clamp(2rem, 3vw, 3rem);
      letter-spacing: -0.04em;
    }
    .brand p {
      margin: 0.7rem 0 0;
      color: var(--muted);
      line-height: 1.55;
    }
    .nav-title {
      margin: 1.25rem 0 0.7rem;
      color: var(--muted);
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .nav {
      display: grid;
      gap: 0.45rem;
    }
    .nav a {
      color: var(--ink);
      text-decoration: none;
      padding: 0.72rem 0.82rem;
      border-radius: 14px;
      border: 1px solid transparent;
      background: transparent;
      transition: 120ms ease;
    }
    .nav a:hover {
      border-color: var(--line);
      background: rgba(92, 200, 255, 0.06);
    }
    .nav a strong {
      display: block;
      font-size: 0.96rem;
    }
    .nav a span {
      display: block;
      margin-top: 0.18rem;
      color: var(--muted);
      font-size: 0.82rem;
    }
    .content {
      min-width: 0;
      padding: 1.6rem 1.5rem 3rem;
    }
    .hero,
    .card {
      border: 1px solid var(--line);
      border-radius: 24px;
      background: var(--panel);
      box-shadow: var(--shadow);
    }
    .hero {
      margin-bottom: 1.4rem;
      padding: 1.3rem;
      background:
        linear-gradient(140deg, rgba(92, 200, 255, 0.08), transparent 45%),
        linear-gradient(180deg, rgba(12, 23, 35, 0.95), rgba(9, 16, 26, 0.96));
    }
    .hero-top {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: start;
    }
    .hero-meta {
      color: var(--muted);
      font-size: 0.96rem;
      line-height: 1.55;
      max-width: 52rem;
    }
    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 0.95rem;
    }
    .actions a {
      color: var(--accent-2);
      text-decoration: none;
      font-size: 0.84rem;
      padding: 0.5rem 0.75rem;
      border-radius: 999px;
      border: 1px solid rgba(110, 247, 210, 0.2);
      background: rgba(110, 247, 210, 0.06);
    }
    .actions a:hover {
      border-color: rgba(110, 247, 210, 0.38);
    }
    .card {
      padding: 1.15rem;
    }
    .card-head {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      align-items: start;
      margin-bottom: 0.75rem;
    }
    .card-title {
      margin: 0;
      font-size: 1.4rem;
    }
    .card-meta {
      margin-top: 0.3rem;
      color: var(--muted);
      font-size: 0.9rem;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.3rem 0.7rem;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      white-space: nowrap;
      border: 1px solid var(--line);
    }
    .ok { color: var(--ok); border-color: rgba(57, 217, 138, 0.36); background: rgba(57, 217, 138, 0.08); }
    .review { color: var(--review); border-color: rgba(92, 200, 255, 0.34); background: rgba(92, 200, 255, 0.08); }
    .warn { color: var(--warn); border-color: rgba(255, 184, 77, 0.34); background: rgba(255, 184, 77, 0.08); }
    .fail { color: var(--fail); border-color: rgba(255, 107, 129, 0.34); background: rgba(255, 107, 129, 0.08); }
    .host-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.8rem;
      margin-top: 1rem;
    }
    .section-card {
      padding: 0.9rem 1rem;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: var(--panel-strong);
    }
    .section-card h3 {
      margin: 0 0 0.65rem;
      font-size: 0.88rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .row {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.35rem 0;
      border-top: 1px dashed rgba(142, 166, 192, 0.16);
      font-size: 0.92rem;
    }
    .row:first-of-type { border-top: 0; }
    .label { color: var(--muted); }
    .list {
      display: grid;
      gap: 0.5rem;
      margin-top: 0.85rem;
    }
    .list-item {
      padding: 0.72rem 0.8rem;
      border-radius: 14px;
      border: 1px solid rgba(111, 142, 178, 0.16);
      background: rgba(255, 255, 255, 0.02);
    }
    .list-item strong {
      display: block;
      font-size: 0.93rem;
    }
    .list-item span {
      display: block;
      margin-top: 0.18rem;
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.45;
    }
    .note-list {
      margin: 0.45rem 0 0;
      padding-left: 1.1rem;
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.5;
    }
    .note-list li + li {
      margin-top: 0.2rem;
    }
    .error {
      margin-top: 0.75rem;
      padding: 0.75rem;
      border-radius: 16px;
      border: 1px solid rgba(255, 107, 129, 0.28);
      background: rgba(255, 107, 129, 0.08);
      color: #ffdbe2;
      font-size: 0.9rem;
    }
    .stale {
      margin-top: 0.75rem;
      color: var(--warn);
      font-size: 0.85rem;
      font-weight: 600;
    }
    .empty,
    .muted {
      color: var(--muted);
    }
    .empty {
      font-size: 0.9rem;
      padding: 0.5rem 0 0.2rem;
    }
    @media (max-width: 980px) {
      .app {
        grid-template-columns: 1fr;
      }
      .sidebar {
        position: static;
        height: auto;
        border-right: 0;
        border-bottom: 1px solid var(--line);
      }
      .content {
        padding-top: 1.2rem;
      }
      .hero-top,
      .card-head {
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div class="brand">
        <div class="eyebrow mono">host detail</div>
        <h1 id="sidebar-host">{{ monitoring_web_title }}</h1>
        <p>One-host view over the published monitoring contracts. Fleet summary stays on the main page.</p>
      </div>
      <div class="nav-title">Overview</div>
      <nav class="nav">
        <a href="../../index.html"><strong>Fleet Summary</strong><span>Return to the fleet overview</span></a>
        <a href="./status.json"><strong>status.json</strong><span>Raw host status contract</span></a>
        <a href="./docker-tag.json"><strong>docker-tag.json</strong><span>Raw Docker tag review contract</span></a>
      </nav>
      <div class="nav-title">Hosts</div>
      <nav class="nav" id="host-nav"></nav>
    </aside>

    <main class="content">
      <section class="hero">
        <div class="hero-top">
          <div>
            <div class="eyebrow mono" id="hero-status">Loading</div>
            <h1 id="hero-title">{{ monitoring_web_title }}</h1>
            <div class="hero-meta" id="hero-meta">Waiting for host contracts.</div>
          </div>
          <div class="actions">
            <a href="../../index.html">Fleet summary</a>
            <a href="../../index.json">index.json</a>
          </div>
        </div>
      </section>

      <section id="host-detail"></section>
    </main>
  </div>

  <script>
    const heroStatusEl = document.getElementById('hero-status');
    const heroTitleEl = document.getElementById('hero-title');
    const heroMetaEl = document.getElementById('hero-meta');
    const sidebarHostEl = document.getElementById('sidebar-host');
    const hostDetailEl = document.getElementById('host-detail');
    const hostNavEl = document.getElementById('host-nav');

    function statusClass(value) {
      return ['ok', 'review', 'warn', 'fail'].includes(value) ? value : 'warn';
    }

    function statusText(value) {
      return value || 'unknown';
    }

    function detail(path, fallback = 'n/a') {
      return path ?? fallback;
    }

    function safeNumber(value, fallback = 0) {
      return typeof value === 'number' && Number.isFinite(value) ? value : fallback;
    }

    function safeArray(value) {
      return Array.isArray(value) ? value : [];
    }

    function row(label, value) {
      return `<div class="row"><span class="label">${label}</span><span>${value}</span></div>`;
    }

    function renderList(title, items, renderer, emptyText = 'No data reported.') {
      if (!items.length) {
        return `<section class="section-card"><h3>${title}</h3><div class="empty">${emptyText}</div></section>`;
      }
      return `
        <section class="section-card">
          <h3>${title}</h3>
          <div class="list">${items.map(renderer).join('')}</div>
        </section>
      `;
    }

    function titleCaseWords(value) {
      return String(value || '')
        .split(/\s+/)
        .filter(Boolean)
        .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
        .join(' ');
    }

    function humanizeDeviceLabel(value) {
      const cleaned = String(value || 'device')
        .replace(/[_-]+/g, ' ')
        .replace(/([a-z])([0-9])/gi, '$1 $2')
        .trim();
      return titleCaseWords(cleaned || 'device');
    }

    function healthLabel(value) {
      if (value === 'ok') return 'Healthy';
      if (value === 'fail') return 'Failing';
      if (value === 'warn') return 'Warning';
      if (value === 'review') return 'Review';
      return titleCaseWords(value || 'Unknown');
    }

    function mountItem(mount) {
      return `
        <div class="list-item">
          <strong>${mount.mount || 'unknown mount'} <span class="muted mono">${mount.used_pct ?? 'n/a'}%</span></strong>
          <span>${mount.source || 'unknown source'}</span>
        </div>
      `;
    }

    function extractSmartAssessment(summary) {
      const text = String(summary || '');
      if (!text) return '';
      const passedMatch = text.match(/SMART overall-health self-assessment test result:\s*PASSED/i);
      if (passedMatch) return 'SMART self-assessment: PASSED';
      const failedMatch = text.match(/SMART overall-health self-assessment test result:\s*FAILED!?/i);
      if (failedMatch) return 'SMART self-assessment: FAILED';
      return '';
    }

    function extractSmartNotes(summary) {
      const text = String(summary || '');
      const notes = [];
      if (/SMART Status not supported/i.test(text)) {
        notes.push('USB bridge note: full SMART status is limited on this device');
      }
      if (/Attribute check/i.test(text)) {
        notes.push('Result is based on an attribute-level health check');
      }
      return notes;
    }

    function describeDevice(device) {
      const details = device.details || {};
      if (device.type === 'nvme') {
        const criticalWarning = safeNumber(details.critical_warning, 0);
        const mediaErrors = safeNumber(details.media_errors, 0);
        const errorLogEntries = safeNumber(details.error_log_entries, 0);
        if (criticalWarning === 0 && mediaErrors === 0 && errorLogEntries === 0) {
          return ['No critical warnings, no media errors, no error log entries'];
        }
        return [
          `Critical warnings: ${criticalWarning}`,
          `Media errors: ${mediaErrors}`,
          `Error log entries: ${errorLogEntries}`,
        ];
      }

      if (device.type === 'sd') {
        const lookback = details.sd_error_lookback || 'recent checks';
        const errorCount = safeNumber(details.sd_error_count, 0);
        if (errorCount === 0) {
          return [`No SD I/O errors seen in the last ${lookback}`];
        }
        return [`${errorCount} SD I/O error${errorCount === 1 ? '' : 's'} seen in the last ${lookback}`];
      }

      if (device.type === 'smart') {
        const summary = String(details.smart_summary || '');
        const assessment = extractSmartAssessment(summary);
        const notes = extractSmartNotes(summary);
        if (assessment || notes.length) {
          return [assessment || 'SMART data collected', ...notes];
        }
      }

      return Object.entries(details)
        .map(([key, value]) => `${key.replace(/_/g, ' ')}: ${Array.isArray(value) ? value.join(', ') : value}`);
    }

    function deviceItem(device) {
      const lines = describeDevice(device)
        .filter(Boolean)
        .map((line) => `<span>${line}</span>`)
        .join('');
      return `
        <div class="list-item">
          <strong>${humanizeDeviceLabel(device.label || device.device || 'device')} <span class="${statusClass(device.status)}">${healthLabel(device.status)}</span></strong>
          <span class="mono">${device.device || 'n/a'}</span>
          ${lines}
        </div>
      `;
    }

    function dockerTagContractStatus(host) {
      const dockerTag = host.docker_tag || {};
      const details = dockerTag.details || {};
      if (safeNumber(details.lookup_error_count, 0) > 0) {
        return 'review';
      }
      if (safeNumber(details.update_available_count, 0) > 0) {
        return 'review';
      }
      return dockerTag.status || 'ok';
    }

    function updateDecisionLabel(item) {
      if (item.tracking === 'lookup_error') return 'Lookup error';
      if (item.tracking === 'floating') return 'Floating tag';
      if (item.tracking === 'non_semver') return 'Non-semver';
      if (!item.update_available) return 'Current';
      return item.ok_to_update ? 'OK to update' : 'Review first';
    }

    function trackingLabel(item) {
      if (item.tracking === 'lookup_error') return 'Lookup error';
      if (item.tracking === 'floating') return 'Floating tag';
      if (item.tracking === 'non_semver') return 'Non-semver';
      if (item.tracking === 'semantic') return 'Semantic tag';
      return item.tracking || 'unknown';
    }

    function dockerTagItemClass(item) {
      if (item.tracking === 'lookup_error') return 'review';
      if (item.update_available) return 'review';
      return 'ok';
    }

    function updateItem(item) {
      const notes = safeArray(item.notes);
      const latest = item.latest_tag || 'n/a';
      const backupLine = item.should_have_backup
        ? (item.backup_host_enabled
          ? `Host backup enabled${item.backup_stop_configured ? ' | stop-before-backup configured' : ''}`
          : 'Writable state detected | no host backup configured')
        : 'Low-state or stateless heuristic';
      const notesHtml = notes.length
        ? `<ul class="note-list">${notes.map((note) => `<li>${note}</li>`).join('')}</ul>`
        : '';
      return `
        <div class="list-item">
          <strong>${item.name || 'container'} <span class="${dockerTagItemClass(item)}">${updateDecisionLabel(item)}</span></strong>
          <span class="mono">${item.image || 'n/a'}</span>
          <span>Current tag: ${item.current_tag || 'n/a'}</span>
          <span>Latest tag: ${latest}</span>
          <span>Update type: ${item.bump_type || 'none'} | Tracking: ${trackingLabel(item)}</span>
          <span>Platform: ${item.target_platform || 'n/a'}${item.resolved_platform ? ` | resolved ${item.resolved_platform}` : ''}</span>
          <span>Backup note: ${backupLine}${item.backup_recommended ? ' | backup review recommended' : ''}</span>
          ${notesHtml}
        </div>
      `;
    }

    function rawLinks() {
      const links = [
        `<a href="./status.json">status.json</a>`,
        `<a href="./storage-health.json">storage-health.json</a>`,
        `<a href="./docker-tag.json">docker-tag.json</a>`,
        `<a href="./restic-backup.json">restic-backup.json</a>`,
      ];
      return `<div class="actions">${links.join('')}</div>`;
    }

    function navigationItem(host) {
      return `
        <a href="../../hosts/${host.name}/index.html">
          <strong>${host.display_name || host.name}</strong>
          <span>${statusText(host.summary_status)}${host.stale ? ' | stale cache' : ''}</span>
        </a>
      `;
    }

    function inferHostName() {
      const parts = window.location.pathname.split('/').filter(Boolean);
      const hostsIndex = parts.indexOf('hosts');
      if (hostsIndex >= 0 && parts.length > hostsIndex + 1) {
        return parts[hostsIndex + 1];
      }
      return 'unknown';
    }

    async function fetchJson(path, optional = false) {
      const response = await fetch(path, { cache: 'no-store' });
      if (!response.ok) {
        if (optional && response.status === 404) {
          return null;
        }
        throw new Error(`${path} returned HTTP ${response.status}`);
      }
      return response.json();
    }

    function renderHost(host) {
      const status = host.status || {};
      const storage = host.storage_health || {};
      const dockerTag = host.docker_tag || {};
      const dockerTagDetails = dockerTag.details || {};
      const backup = host.backup || {};
      const backupStatus = status?.details?.backup_status || (backup ? backup.status : 'missing');
      const backupContractStatus = backup?.status || backupStatus;
      const errors = Object.entries(host.errors || {}).filter(([, value]) => value);
      const mounts = safeArray(status?.details?.storage_mounts);
      const devices = safeArray(storage?.details?.devices);
      const dockerTagItems = safeArray(dockerTagDetails?.containers);
      const memoryUsed = status?.details?.memory_used_pct;
      const loadPerCpu = status?.details?.system_load_per_cpu_1m;
      const lastBackupAge = status?.details?.backup_last_success_age_hours;
      const containersRunning = status?.details?.containers_running;
      const containersTotal = status?.details?.containers_total;
      const dockerTagError = host.errors?.docker_tag;
      const dockerTagEmptyText = dockerTagError
        ? `Collector could not refresh docker-tag.json: ${dockerTagError}`
        : (dockerTagDetails?.tracked_container_count || dockerTagItems.length
          ? 'No container tag rows matched the current view.'
          : 'No Docker tag data collected yet.');
      return `
        <article class="card">
          <div class="card-head">
            <div>
              <h2 class="card-title">${host.display_name || host.name}</h2>
              <div class="card-meta">${host.name}${host.ssh_host ? ` • ${host.ssh_host}` : ''}${host.local ? ' • local collector source' : ''}</div>
            </div>
            <div class="pill ${statusClass(host.summary_status)}">${statusText(host.summary_status)}</div>
          </div>
          <div class="host-grid">
            <section class="section-card">
              <h3>Quick Status</h3>
              ${row('Host', statusText(status.status))}
              ${row('Storage', statusText(storage.status))}
              ${row('Container tags', statusText(dockerTagContractStatus(host)))}
              ${row('Backup', statusText(backupStatus))}
              ${row('Docker', detail(status?.checks?.docker, 'n/a'))}
              ${row('System', detail(status?.checks?.system, 'n/a'))}
            </section>
            <section class="section-card">
              <h3>System Snapshot</h3>
              ${row('Memory used', memoryUsed === undefined ? 'n/a' : `${memoryUsed}%`)}
              ${row('Load / CPU', loadPerCpu === undefined ? 'n/a' : loadPerCpu)}
              ${row('Containers', containersRunning === undefined ? 'n/a' : `${containersRunning}/${containersTotal}`)}
              ${row('Pending tag updates', detail(dockerTagDetails?.update_available_count, 0))}
              ${row('Last backup age', lastBackupAge === undefined || lastBackupAge < 0 ? 'n/a' : `${lastBackupAge}h`)}
              ${row('Tracked devices', detail(storage?.details?.device_count, 0))}
            </section>
            <section class="section-card">
              <h3>Contracts</h3>
              ${row('Status JSON', host.status ? 'present' : 'missing')}
              ${row('Storage JSON', host.storage_health ? 'present' : 'missing')}
              ${row('Docker Tag JSON', host.docker_tag ? 'present' : 'missing')}
              ${row('Backup JSON', host.backup ? 'present' : 'missing')}
              ${row('Warnings', safeNumber(storage?.details?.warning_device_count, 0))}
              ${row('Failures', safeNumber(storage?.details?.failing_device_count, 0))}
            </section>
            <section class="section-card">
              <h3>Tag Guidance</h3>
              ${row('Host platform', detail(dockerTagDetails?.host_platform?.label, 'n/a'))}
              ${row('Tracked containers', detail(dockerTagDetails?.tracked_container_count, 0))}
              ${row('Safe to update', detail(dockerTagDetails?.ok_to_update_count, 0))}
              ${row('Review first', detail(dockerTagDetails?.review_required_count, 0))}
              ${row('Backup recommended', detail(dockerTagDetails?.backup_recommended_count, 0))}
              ${row('Floating tags', detail(dockerTagDetails?.floating_tag_count, 0))}
            </section>
            <section class="section-card">
              <h3>Backup Detail</h3>
              ${row('Summary state', statusText(backupStatus))}
              ${row('Raw contract', statusText(backupContractStatus))}
              ${row('Timestamp', detail(backup?.timestamp, status?.details?.backup_timestamp || 'n/a'))}
              ${row('Exit code', detail(backup?.exit_code, status?.details?.backup_exit_code ?? 'n/a'))}
              ${row('Error', detail(backup?.error, status?.details?.backup_error || 'none'))}
            </section>
          </div>
          <div class="host-grid">
            ${renderList('Mount Usage', mounts, mountItem, 'No mount usage data collected yet.')}
            ${renderList('Device Health', devices, deviceItem, 'No per-device storage health data collected yet.')}
            ${renderList('Container Tag Detail', dockerTagItems, updateItem, dockerTagEmptyText)}
          </div>
          ${rawLinks()}
          ${host.stale ? '<div class="stale">Using one or more stale cached contracts because the latest fetch failed.</div>' : ''}
          ${errors.length ? `<div class="error">${errors.map(([key, value]) => `<strong>${key}</strong>: ${value}`).join('<br>')}</div>` : ''}
        </article>
      `;
    }

    async function load() {
      const hostName = inferHostName();
      const [indexData, status, storage, dockerTag, backup] = await Promise.all([
        fetchJson('../../index.json', true),
        fetchJson('./status.json'),
        fetchJson('./storage-health.json', true),
        fetchJson('./docker-tag.json', true),
        fetchJson('./restic-backup.json', true),
      ]);

      const hosts = Array.isArray(indexData?.hosts) ? indexData.hosts : [];
      const hostMeta = hosts.find((item) => item.name === hostName) || {
        name: hostName,
        display_name: hostName,
        ssh_host: '',
        ssh_user: '',
        local: false,
        summary_status: 'ok',
        stale: false,
        errors: {},
      };

      const host = {
        ...hostMeta,
        status: status || null,
        storage_health: storage || null,
        docker_tag: dockerTag || null,
        backup: backup || null,
      };

      sidebarHostEl.textContent = host.display_name || host.name;
      heroTitleEl.textContent = host.display_name || host.name;
      heroStatusEl.className = `eyebrow mono ${statusClass(host.summary_status)}`;
      heroStatusEl.textContent = statusText(host.summary_status);
      heroMetaEl.innerHTML = `Host <span class="mono">${host.name}</span>${host.ssh_host ? ` at <span class="mono">${host.ssh_host}</span>` : ''} updated through the collected contracts. Docker tag updates stay review-only unless the registry lookup itself failed.`;
      hostNavEl.innerHTML = hosts.map(navigationItem).join('');
      hostDetailEl.innerHTML = renderHost(host);
    }

    load().catch((error) => {
      heroStatusEl.className = 'eyebrow mono fail';
      heroStatusEl.textContent = 'fail';
      heroMetaEl.textContent = 'The host page could not load its contracts.';
      hostDetailEl.innerHTML = `<div class="error">${error}</div>`;
    });
    setInterval(load, 60000);
  </script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('../../service-worker.js').catch(() => {});
      });
    }
  </script>
</body>
</html>
