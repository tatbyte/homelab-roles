{# roles/monitoring_web/templates/monitor-collect-web-compose.yml.j2 #}
# Managed by Ansible: monitoring_collect
# Source: roles/monitoring_web/templates/monitor-collect-web-compose.yml.j2
services:
  {{ monitoring_web_compose_service_name }}:
    image: {{ monitoring_web_image }}
    container_name: {{ monitoring_web_container_name }}
    restart: unless-stopped
    volumes:
      - {{ monitoring_web_publish_dir }}:/usr/share/nginx/html:ro
      - {{ monitoring_web_nginx_conf_path }}:/etc/nginx/conf.d/default.conf:ro
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ monitoring_web_proxy_network_name }}"
      - "traefik.http.routers.{{ monitoring_web_router_name }}.rule=Host(`{{ monitoring_web_effective_host }}`)"
      - "traefik.http.routers.{{ monitoring_web_router_name }}.entrypoints={{ monitoring_web_router_entrypoints | join(',') }}"
      - "traefik.http.routers.{{ monitoring_web_router_name }}.tls=true"
      - "traefik.http.routers.{{ monitoring_web_router_name }}.tls.certresolver={{ monitoring_web_tls_certresolver }}"
{% if monitoring_web_effective_basic_auth_enabled %}
      - "traefik.http.routers.{{ monitoring_web_router_name }}.middlewares={{ monitoring_web_basic_auth_middleware }}"
      - "traefik.http.middlewares.{{ monitoring_web_basic_auth_middleware }}.basicauth.users={{ monitoring_web_effective_basic_auth_users | map('replace', '$', '$$') | join(',') }}"
{% endif %}
      - "traefik.http.services.{{ monitoring_web_router_name }}.loadbalancer.server.port={{ monitoring_web_container_port }}"
    networks:
      - proxy

networks:
  proxy:
    external: true
    name: {{ monitoring_web_proxy_network_name }}
