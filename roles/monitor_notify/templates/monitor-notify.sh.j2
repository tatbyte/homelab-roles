{# roles/monitor_notify/templates/monitor-notify.sh.j2 #}
#!/usr/bin/env bash
# Managed by Ansible: monitor_notify
# Source: roles/monitor_notify/templates/monitor-notify.sh.j2

set -euo pipefail
umask 077

index_path={{ monitor_notify_index_path | to_json }}
state_hash_path={{ monitor_notify_state_hash_path | to_json }}
status_path={{ monitor_notify_status_path | to_json }}
ntfy_url={{ monitor_notify_ntfy_url | to_json }}
title_prefix={{ monitor_notify_ntfy_title_prefix | to_json }}
ntfy_priority={{ monitor_notify_ntfy_priority | to_json }}
host_name={{ monitor_notify_status_host | to_json }}
job_name={{ monitor_notify_job_name | to_json }}
json_schema={{ monitor_notify_json_schema | to_json }}
include_docker_down={{ monitor_notify_include_docker_down | ternary('true', 'false') | to_json }}
include_backup_failed={{ monitor_notify_include_backup_failed | ternary('true', 'false') | to_json }}
force_test_alert="${MONITOR_NOTIFY_TEST_ALERT:-0}"

ntfy_tags=(
{% for item in monitor_notify_ntfy_tags %}
  {{ item | to_json }}
{% endfor %}
)

write_status_json() {
  local timestamp="$1"
  local role_status="$2"
  local alert_count="$3"
  local notification_sent="$4"
  local notification_reason="$5"
  local error_text="$6"
  local alerts_json="$7"
  local tmp_json
  local tags_json

  tags_json="$(
    printf '%s\n' "${ntfy_tags[@]}" \
      | jq -R -s 'split("\n") | map(select(length > 0))'
  )"

  tmp_json="$(mktemp "${status_path}.XXXXXX")"
  jq -n \
    --arg schema "$json_schema" \
    --arg host "$host_name" \
    --arg job "$job_name" \
    --arg timestamp "$timestamp" \
    --arg status "$role_status" \
    --arg index_path "$index_path" \
    --arg notification_reason "$notification_reason" \
    --arg error "$error_text" \
    --argjson alert_count "$alert_count" \
    --argjson notification_sent "$notification_sent" \
    --argjson alerts "$alerts_json" \
    --argjson tags "$tags_json" \
    '{
      schema: $schema,
      host: $host,
      job: $job,
      timestamp: $timestamp,
      status: $status,
      details: {
        index_path: $index_path,
        alert_count: $alert_count,
        alerts: $alerts,
        notification_sent: $notification_sent,
        notification_reason: $notification_reason,
        ntfy_tags: $tags,
        error: $error
      }
    }' >"$tmp_json"
  mv "$tmp_json" "$status_path"
}

timestamp="$(date --iso-8601=ns)"
mkdir -p "$(dirname "$status_path")" "$(dirname "$state_hash_path")"

if [ ! -f "$index_path" ]; then
  write_status_json "$timestamp" fail 0 false missing_index "collector index not found" '[]'
  exit 1
fi

if ! alerts_json="$(
  jq -c -n \
    --slurpfile index "$index_path" \
    --argjson include_docker_down "$include_docker_down" \
    --argjson include_backup_failed "$include_backup_failed" \
    '
    ($index[0].hosts // []) as $hosts
    | [
        $hosts[] as $host
        | (
            if $include_docker_down then
              ($host.status.details.docker_non_running_containers // [])
              | map(select(type == "string"))
              | if length > 0 then
                  {
                    type: "docker_down",
                    host_name: ($host.name // ""),
                    display_name: ($host.display_name // $host.name // "unknown"),
                    summary: ((length | tostring) + " Docker container(s) down"),
                    message: (($host.display_name // $host.name // "unknown") + ": non-running containers: " + (join(", "))),
                    details: { containers: . }
                  }
                else empty end
            else empty end
          ),
          (
            if $include_backup_failed and (($host.backup.status // "") == "error") then
              {
                type: "backup_failed",
                host_name: ($host.name // ""),
                display_name: ($host.display_name // $host.name // "unknown"),
                summary: "Backup failed",
                message: (
                  ($host.display_name // $host.name // "unknown")
                  + ": backup failed"
                  + (
                      if (($host.backup.error // "") | length) > 0
                      then " (" + ($host.backup.error // "") + ")"
                      else ""
                    end
                    )
                ),
                details: {
                  error: ($host.backup.error // ""),
                  exit_code: ($host.backup.exit_code // 0)
                }
              }
            else empty end
          )
      ]'
)"; then
  write_status_json "$timestamp" fail 0 false invalid_index "collector index is missing or invalid JSON" '[]'
  exit 1
fi

alert_count="$(jq -nr --argjson alerts "$alerts_json" '$alerts | length')"

if [ "$alert_count" -eq 0 ]; then
  if [ "$force_test_alert" = "1" ]; then
    title="${title_prefix} test signal"
    notification_body="$(
      jq -nr \
        --arg collector "$host_name" \
        --arg timestamp "$timestamp" \
        '
        [
          "Collector: " + $collector,
          "Timestamp: " + $timestamp,
          "",
          "All monitored contracts look clean right now.",
          "No failed backups are present in the collected backup contracts.",
          "No non-running Docker containers are reported by the monitored hosts.",
          "",
          "This is a deliberate ntfy test signal from monitor_notify_now."
        ] | join("\n")
        '
    )"

    curl_cmd=(
      curl
      -fsS
      -X POST
      -H "Title: ${title}"
      -H "Priority: ${ntfy_priority}"
    )

    tags_csv="$(printf '%s\n' "${ntfy_tags[@]}" | sed '/^$/d' | paste -sd ',' -)"
    if [ -n "$tags_csv" ]; then
      curl_cmd+=(-H "Tags: ${tags_csv}")
    fi

    if ! "${curl_cmd[@]}" --data-binary "$notification_body" "$ntfy_url"; then
      write_status_json "$timestamp" fail 0 false test_send_failed "failed to post test notification to ntfy" "$alerts_json"
      exit 1
    fi

    write_status_json "$timestamp" ok 0 true test_sent "" "$alerts_json"
    exit 0
  fi

  rm -f "$state_hash_path"
  write_status_json "$timestamp" ok 0 false none "" "$alerts_json"
  exit 0
fi

alerts_hash="$(printf '%s' "$alerts_json" | sha256sum | awk '{print $1}')"
previous_hash=""
if [ -f "$state_hash_path" ]; then
  previous_hash="$(tr -d '\n' <"$state_hash_path")"
fi

if [ "$alerts_hash" = "$previous_hash" ]; then
  write_status_json "$timestamp" warn "$alert_count" false unchanged "" "$alerts_json"
  exit 0
fi

notification_body="$(
  jq -nr \
    --arg collector "$host_name" \
    --arg timestamp "$timestamp" \
    --argjson alerts "$alerts_json" \
    '
    [
      "Collector: " + $collector,
      "Timestamp: " + $timestamp,
      "",
      ($alerts[] | "- " + .message)
    ] | join("\n")
    '
)"

title="${title_prefix} alert (${alert_count})"
curl_cmd=(
  curl
  -fsS
  -X POST
  -H "Title: ${title}"
  -H "Priority: ${ntfy_priority}"
)

tags_csv="$(printf '%s\n' "${ntfy_tags[@]}" | sed '/^$/d' | paste -sd ',' -)"
if [ -n "$tags_csv" ]; then
  curl_cmd+=(-H "Tags: ${tags_csv}")
fi

if ! "${curl_cmd[@]}" --data-binary "$notification_body" "$ntfy_url"; then
  write_status_json "$timestamp" fail "$alert_count" false send_failed "failed to post notification to ntfy" "$alerts_json"
  exit 1
fi

printf '%s\n' "$alerts_hash" >"$state_hash_path"
chmod 0600 "$state_hash_path"
write_status_json "$timestamp" warn "$alert_count" true sent "" "$alerts_json"
