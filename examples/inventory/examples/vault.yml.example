---
# examples/inventory/examples/vault.yml.example
# Example secret-bearing variables for the local lab.
# Copy this to `~/.config/ansible/lab_vault.yml` and encrypt it with
# `ansible-vault` for local use.

# ---------------------------------------------------------------------------
# bootstrap
# ---------------------------------------------------------------------------

# Password used for the initial bootstrap SSH login.
vault_bootstrap_login_password: "replace-me"

# Optional separate sudo password for the bootstrap login account.
# Omit this key entirely when SSH and sudo share the same password.
vault_bootstrap_login_become_password: "replace-me"

# ---------------------------------------------------------------------------
# user_password
# ---------------------------------------------------------------------------

# Example hashed password input for the managed human admin account.
vault_user_password_hash: "$6$replace-me"

# ---------------------------------------------------------------------------
# docker_traefik
# ---------------------------------------------------------------------------

# Example ACME contact email used by Traefik for Let's Encrypt registration.
vault_docker_traefik_acme_email: "admin@example.com"

# Shared public domain suffix used to build Traefik and AdGuard dashboard
# hostnames from the inventory `alias`.
vault_docker_public_domain_suffix: "example.com"

# Example DNS provider credential used by Traefik for ACME DNS-01.
vault_docker_traefik_dns_api_token: "replace-me"

# Example Traefik dashboard basic-auth entries in `user:hash` format.
# Generate hashes with `htpasswd -nB <user>`.
vault_docker_traefik_dashboard_basic_auth_users:
  - "admin:replace-me-with-htpasswd-hash"

# ---------------------------------------------------------------------------
# docker_adguard
# ---------------------------------------------------------------------------

# Example AdGuard Home admin credential in `user:bcrypt-hash` form.
# Keep the username and AdGuard-compatible bcrypt hash together here, and keep
# the leading `$` in the bcrypt value.
vault_docker_adguard_admin_credentials: "admin:$2a$10$replace-me"

# ---------------------------------------------------------------------------
# docker_adguard_sync
# ---------------------------------------------------------------------------

# Example public host name used by Traefik for the AdGuard Sync dashboard.
vault_docker_adguard_sync_host: "adguard-sync.example.com"

# Example direct LAN IP for the origin AdGuard instance.
vault_docker_adguard_sync_origin_ip: "192.168.1.53"

# Example direct LAN IP for the replica AdGuard instance.
vault_docker_adguard_sync_replica_ip: "192.168.1.54"

# Example plaintext AdGuard admin password used by the sync tool.
# This must match the bcrypt-backed AdGuard admin account stored in
# `vault_docker_adguard_admin_credentials`.
vault_docker_adguard_sync_adguard_password: "replace-me"

# Example AdGuard Sync dashboard/API username.
# Leave the committed example blank on purpose so secret scanners do not treat
# this adjacent username/password pair as a real credential.
vault_docker_adguard_sync_api_username: ""

# Example AdGuard Sync dashboard/API password.
vault_docker_adguard_sync_api_password: ""

# ---------------------------------------------------------------------------
# docker_wireguard
# ---------------------------------------------------------------------------

# Example public host name used by both the wg-easy initial setup and the
# Traefik router for the WireGuard dashboard.
vault_docker_wireguard_host: "wireguard.example.com"

# Optional separate VPN endpoint host name passed to wg-easy as `INIT_HOST`.
# Set this when WireGuard clients should connect through DuckDNS or another
# DDNS name while the dashboard stays on `vault_docker_wireguard_host`.
# Omit this key entirely to reuse `vault_docker_wireguard_host`.
vault_docker_wireguard_duckdns_host: "myhomelabvpn.duckdns.org"

# Example initial admin username for the wg-easy dashboard.
vault_docker_wireguard_admin_username: "admin"

# Example initial admin password for the wg-easy dashboard.
# Use the plain password value here; the upstream unattended setup uses
# `INIT_PASSWORD`, not a password-hash field.
# The upstream wg-easy docs do not enforce password complexity, but they do say
# to use a long enough password or login may fail. This repo recommends at
# least 12 characters.
vault_docker_wireguard_admin_password: "replace-me"

# Example DNS resolvers pushed to WireGuard clients on first setup.
# Use resolver IPs here. This example shows two AdGuard instances.
vault_docker_wireguard_init_dns:
  - "192.168.1.53"
  - "192.168.1.54"

# ---------------------------------------------------------------------------
# backup_restic
# ---------------------------------------------------------------------------

# Example Restic repository target for IDrive e2 through the S3-compatible
# API.
# Replace the region, bucket, and path with your real IDrive e2 values.
vault_backup_restic_idrive_e2_repository: "s3:https://s3.ca-east-1.idrivee2.com/example-lab/restic"

# Example IDrive e2 region used by the S3-compatible API.
vault_backup_restic_idrive_e2_region: "ca-east-1"

# Example IDrive e2 access key ID for the S3-compatible API.
vault_backup_restic_idrive_e2_access_key_id: "replace-me"

# Example IDrive e2 secret access key for the S3-compatible API.
vault_backup_restic_idrive_e2_secret_access_key: "replace-me"

# Example Restic repository password.
vault_backup_restic_password: "replace-me"

# ---------------------------------------------------------------------------
# monitoring_collect
# ---------------------------------------------------------------------------

# Optional dedicated SSH private key used by the collector host when
# `monitoring_collect_ssh_manage_private_key` is enabled.
vault_monitoring_collect_ssh_private_key: |
  replace-me-with-your-monitor-collect-private-key

# Matching public key installed on the remote monitored hosts through
# `monitoring_authorized_key`.
vault_monitoring_collect_ssh_public_key: "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIExampleMonitorCollectPublicKey collector@example.invalid"

# ---------------------------------------------------------------------------
# monitoring_web
# ---------------------------------------------------------------------------

# Optional public hostname published by Traefik for the collected monitoring
# dashboard.
vault_monitoring_collect_web_host: "monitor.example.com"

# Optional dashboard title shown on the collected monitoring page.
vault_monitoring_collect_web_title: "Lab Monitor"

# Optional shorter title used for the installable dashboard on mobile home
# screens.
vault_monitoring_collect_web_short_title: "Monitor"

# Optional Traefik basic-auth entries for the monitoring dashboard, in the same
# `user:hash` format as the Traefik dashboard itself. Leave empty to disable
# auth for the dashboard route.
vault_monitoring_collect_web_basic_auth_users:
  - "monitor:replace-me-with-htpasswd-hash"

# ---------------------------------------------------------------------------
# monitoring_notify
# ---------------------------------------------------------------------------

# Optional ntfy topic URL used by the collector host to send monitoring
# notifications. Leave this unset to keep `monitoring_notify` disabled in the
# example inventory.
vault_monitoring_notify_ntfy_url: "https://ntfy.sh/example-lab-monitor"
