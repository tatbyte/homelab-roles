# .gitignore
# Ignore local artifacts, caches, editor settings, and generated files for this repository.

# Ansible local artifacts
.ansible/
*.retry
vault.vars

# Python virtual environments and caches
.venv/
venv/
__pycache__/
*.py[cod]

# Test and lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE/editor settings
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Added by ggshield
.cache_ggshield
